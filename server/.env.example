# Mistral API Key (required)
MISTRAL_API_KEY=your_mistral_api_key_here

# Models
VOXTRAL_MODEL=voxtral-mini-2507
TRIAGE_MODEL=mistral-large-latest
VISION_MODEL=mistral-small-latest

# MySQL
MYSQL_HOST=
MYSQL_PORT=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
ALLOWED_ORIGINS=["*"]

# Audio
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_DURATION_MS=500

# Triage Engine
TRIAGE_EXTRACTION_INTERVAL_SEC=3.0
MAX_TRANSCRIPT_BUFFER_CHARS=10000
SESSION_TIMEOUT_SEC=3600

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
